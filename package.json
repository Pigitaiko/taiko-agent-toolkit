{
  "name": "@taiko/agent-toolkit",
  "version": "0.1.0",
  "description": "Onchain toolkit for AI agents on the Taiko network",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "taiko-agent": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "lint": "eslint src/",
    "test": "vitest",
    "demo": "npx tsx examples/demo-agent.ts",
    "demo:auto": "npx tsx examples/demo-agent.ts --auto"
  },
  "keywords": [
