# Taiko Agent Toolkit Configuration

# RPC URLs (optional — defaults to public RPCs)
TAIKO_RPC_URL=https://rpc.mainnet.taiko.xyz
TAIKO_HOODI_RPC_URL=https://rpc.hoodi.taiko.xyz
ETHEREUM_RPC_URL=https://eth.llamarpc.com

# Default chain (167000=mainnet, 167013=hoodi testnet)
TAIKO_CHAIN_ID=167000

# Agent Registry contract address (deploy and set)
AGENT_REGISTRY_ADDRESS=

# Wallet encryption password (optional — auto-generated if not set)
WALLET_PASSWORD=
